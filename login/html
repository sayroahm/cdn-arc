      reserved.
    </p>
    <div style="margin-top:28px; display:flex; justify-content:flex-end;">
      <button class="btn btn-primary" onclick="acceptCopyright()">I Acknowledge — Continue</button>
    </div>
  </div>
</div>

<script>
  const urlParams = new URLSearchParams(window.location.search);
  const mode = urlParams.get('mode') || 'test';

  const modeLabels = {
    test:     'Test Sign In',
    admin:    'Administrator Sign In',
    training: 'Training Sign In',
    grader:   'Grader Sign In',
    central:  'Central Administration'
  };

  document.getElementById('modeLabel').textContent    = modeLabels[mode] || 'Sign In';
  document.getElementById('topbarMode').textContent   = modeLabels[mode] || 'Sign In';

  window.addEventListener('load', () => {
    setTimeout(() => document.getElementById('arc-loader').classList.add('hidden'), 1400);
  });

  let currentUser    = null;
  let selectedTestId = null;

  async function doLogin() {
    const baseId   = document.getElementById('baseId').value.trim();
    const password = document.getElementById('password').value.trim();
    const errEl    = document.getElementById('loginError');
    const btn      = document.getElementById('loginBtn');

    if (!baseId || !password) {
      document.getElementById('loginErrorMsg').textContent = 'Both fields are required.';
      errEl.style.display = 'flex'; return;
    }

    btn.classList.add('btn-loading');
    btn.disabled = true;
    errEl.style.display = 'none';

    try {
      const user = await window._arcLogin(baseId, password);
      if (!user) {
        document.getElementById('loginErrorMsg').textContent = 'Invalid Base ID or password.';
        errEl.style.display = 'flex';
        btn.classList.remove('btn-loading');
        btn.disabled = false;
        return;
      }

      currentUser = user;
      sessionStorage.setItem('arc_user', JSON.stringify(user));
      sessionStorage.setItem('arc_mode', mode);

      if ((mode === 'admin' || mode === 'central') &&
          (user.role === 'administrator' || user.role === 'central')) {
        window.location.href = 'admin.html';
        return;
      }

      showUserInfo(user);
    } catch(e) {
      document.getElementById('loginErrorMsg').textContent = 'Connection error. Please try again.';
      errEl.style.display = 'flex';
      btn.classList.remove('btn-loading');
      btn.disabled = false;
    }
  }

  document.getElementById('password').addEventListener('keydown', e => {
    if (e.key === 'Enter') doLogin();
  });

  async function showUserInfo(user) {
    document.getElementById('loginCard').style.display = 'none';
    document.getElementById('infoCard').style.display  = 'block';

    const initials = ((user.first_name || '')[0] || '') + ((user.last_name || '')[0] || '') || '?';
    document.getElementById('userAvatar').textContent = initials.toUpperCase();
    document.getElementById('userName').textContent   =
      [user.first_name, user.last_name].filter(Boolean).join(' ') || user.base_id;
    document.getElementById('userId').textContent     = 'Base ID: ' + user.base_id;
    document.getElementById('userRole').textContent   = (user.role || 'student').charAt(0).toUpperCase() + (user.role || 'student').slice(1);
    document.getElementById('userOrg').textContent    = user.organization || user.school || '—';
    document.getElementById('userGrade').textContent  = user.grade || user.level || '—';
    document.getElementById('userSession').textContent = new Date().toLocaleString();

    const listEl = document.getElementById('testsList');
    listEl.innerHTML = '<div class="no-tests">Loading...</div>';

    try {
      const tests = await window._arcGetTests();
      if (!tests.length) {
        listEl.innerHTML = '<div class="no-tests">No active assessments at this time.</div>';
        return;
      }
      listEl.innerHTML = '';
      tests.forEach(test => {
        const item = document.createElement('div');
        item.className = 'test-item';
        item.innerHTML = `
          <div>
            <div class="test-item-name">${test.name || test.id}</div>
            <div class="test-item-id">${test.subject ? test.subject + ' &nbsp;|&nbsp; ' : ''}ID: ${test.id}</div>
          </div>
          <div class="test-radio"></div>`;
        item.addEventListener('click', () => {
          document.querySelectorAll('.test-item').forEach(el => el.classList.remove('selected'));
          item.classList.add('selected');
          selectedTestId = test.id;
          document.getElementById('continueBtn').disabled = false;
        });
        listEl.appendChild(item);
      });
    } catch {
      listEl.innerHTML = '<div class="no-tests">Unable to load assessments.</div>';
    }
  }

  function handleContinue() {
    if (!selectedTestId) return;
    sessionStorage.setItem('arc_test_id', selectedTestId);
    if (mode === 'test') {
      document.getElementById('copyrightModal').style.display = 'flex';
    } else {
      window.location.href = 'intro.html';
    }
  }

  function acceptCopyright() {
    document.getElementById('copyrightModal').style.display = 'none';
    window.location.href = 'intro.html';
  }
</script>
</body>
</html>
