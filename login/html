  <div class="modal-box">
    <h3>Copyright Notice</h3>
    <div class="divider" style="margin-bottom:20px;"></div>
    <p style="font-size:12px; line-height:1.9; color:var(--text-secondary); font-family:var(--font-ui);">
      All material, content, source code, documentation, and associated works included within this testing
